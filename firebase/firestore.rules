// firebase/firestore.rules
//
// PATHS DEPRECADOS — NÃO USAR:
//   settings/eurRate   → removido na Fase 7 (migration 2026-05-cleanup-fx-settings)
//   settings/usdRate   → removido na Fase 7 (migration 2026-05-cleanup-fx-settings)
//
//   Substituídos pelo FxContext (src/lib/FxContext.jsx) que busca cotações
//   automáticas via AwesomeAPI / Frankfurter / ExchangeRate-API.
//   Arquivos de auditoria em settings/_deprecated/ expiram 30 dias após migration.
//
// VALIDAÇÕES ADICIONADAS NA FASE 7.5:
//   contracts/{id}.data.lockedRate   — number > 0 ou null
//   contracts/{id}.data.lockedRateAt — string ISO 8601 ou null
//   Contratos ficam em data:{} aninhado, por isso regras acessam
//   request.resource.data.data.lockedRate (não request.resource.data.lockedRate).

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function validLockedRate(contractData) {
      let lr = contractData.lockedRate;
      return !('lockedRate' in contractData)
          || lr == null
          || (lr is number && lr > 0);
    }

    function validLockedRateAt(contractData) {
      let lrat = contractData.lockedRateAt;
      return !('lockedRateAt' in contractData)
          || lrat == null
          || lrat is string
          || lrat is timestamp;
    }

    function lockedRateConsistent(contractData) {
      let lr   = contractData.get('lockedRate', null);
      let lrat = contractData.get('lockedRateAt', null);
      return (lr == null) == (lrat == null);
    }

    // ─── Contracts ────────────────────────────────────────────
    match /contracts/{contractId} {
      allow read: if isAuth();

      allow create, update: if isAuth()
        && request.resource.data.id == contractId
        && request.resource.data.data is map
        && validLockedRate(request.resource.data.data)
        && validLockedRateAt(request.resource.data.data)
        && lockedRateConsistent(request.resource.data.data);

      allow delete: if isAuth();
    }

    // ─── Posts ────────────────────────────────────────────────
    match /posts/{postId} {
      allow read, write: if isAuth();
    }

    // ─── Deliverables ─────────────────────────────────────────
    match /deliverables/{delivId} {
      allow read, write: if isAuth();
    }

    // ─── Caixa transactions ───────────────────────────────────
    match /caixa_tx/{txId} {
      allow read, write: if isAuth();
    }

    // ─── Settings ─────────────────────────────────────────────
    // DEPRECADOS — leitura e escrita bloqueadas:
    match /settings/eurRate {
      allow read, write: if false; // DEPRECADO — usar FxContext
    }
    match /settings/usdRate {
      allow read, write: if false; // DEPRECADO — usar FxContext
    }

    // Arquivo de auditoria (30 dias): só leitura pelo app, escrita apenas via Admin SDK
    match /settings/_deprecated/{docId} {
      allow read:  if isAuth();
      allow write: if false; // somente migration server-side (firebase-admin)
    }

    // Demais settings: leitura e escrita autenticada
    match /settings/{key} {
      allow read, write: if isAuth();
    }

    // ─── Brands ───────────────────────────────────────────────
    match /brands/{brandId} {
      allow read, write: if isAuth();
    }

    // ─── Presence (online users) ──────────────────────────────
    match /presence/{sessionId} {
      allow read, write: if isAuth();
    }
  }
}
